#!/usr/bin/env bash

set -euo pipefail

now_ts="$(date +%s)"

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf '%s not found\n' "$1" >&2
    exit 1
  fi
}

to_lower() {
  printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]'
}

detect_theme_color() {
  local accent_option theme

  accent_option="$(tmux show-option -gqv @hal_theme_accent_bg 2>/dev/null || true)"
  case "$accent_option" in
    colour25)
      printf 'blue'
      return
      ;;
    colour28)
      printf 'green'
      return
      ;;
    colour52)
      printf 'red'
      return
      ;;
  esac

  theme="$(to_lower "${HAL_THEME_COLOR:-red}")"
  case "$theme" in
    blue|green|red)
      printf '%s' "$theme"
      ;;
    *)
      printf 'red'
      ;;
  esac
}

ansi_hex() {
  local hex="${1#\#}"
  local r g b

  r=$((16#${hex:0:2}))
  g=$((16#${hex:2:2}))
  b=$((16#${hex:4:2}))

  printf '\033[38;2;%d;%d;%dm' "$r" "$g" "$b"
}

theme_color="$(detect_theme_color)"
case "$theme_color" in
  blue)
    accent_hex='#60a5fa'
    accent_soft_hex='#93c5fd'
    border_hex='#1d4ed8'
    ;;
  green)
    accent_hex='#4ade80'
    accent_soft_hex='#86efac'
    border_hex='#166534'
    ;;
  red|*)
    accent_hex='#f87171'
    accent_soft_hex='#fca5a5'
    border_hex='#7f1d1d'
    ;;
esac

fg_hex='#f8fafc'
bright_hex='#ffffff'
dim_hex='#888888'
muted_hex='#666666'
warm_hex='#ffd75f'
row_hex='#1a1a1a'

color_reset=$'\033[0m'
color_bold=$'\033[1m'
color_fg="$(ansi_hex "$fg_hex")"
color_bright="$(ansi_hex "$bright_hex")"
color_dim="$(ansi_hex "$dim_hex")"
color_muted="$(ansi_hex "$muted_hex")"
color_accent="$(ansi_hex "$accent_hex")"
color_soft="$(ansi_hex "$accent_soft_hex")"
color_warm="$(ansi_hex "$warm_hex")"

# Command-type colors (pre-computed to avoid per-window subshells)
color_cmd_shell="$(ansi_hex '#7aa2f7')"    # soft blue  — idle terminal
color_cmd_editor="$(ansi_hex '#9ece6a')"   # green      — editing
color_cmd_devrun="$(ansi_hex '#e0af68')"   # amber      — running process
color_cmd_git="$(ansi_hex '#bb9af7')"      # lavender   — version control
color_cmd_filemgr="$(ansi_hex '#73daca')"  # teal       — file browsing
color_cmd_system="$(ansi_hex '#f7768e')"   # rose       — system/monitoring
color_cmd_remote="$(ansi_hex '#ff9e64')"   # orange     — remote connection
color_cmd_other="$(ansi_hex '#a9b1d6')"    # silver     — fallback

shorten_home() {
  local path="${1:-}"

  if [[ -z "$path" ]]; then
    printf -- '-'
    return
  fi

  if [[ "$path" == "$HOME" ]]; then
    printf '~'
  elif [[ "$path" == "$HOME/"* ]]; then
    printf '~/%s' "${path#$HOME/}"
  else
    printf '%s' "$path"
  fi
}

truncate_right() {
  local text="${1:-}"
  local max="${2:-0}"

  if (( ${#text} <= max )); then
    printf '%s' "$text"
  elif (( max > 3 )); then
    printf '%s...' "${text:0:max-3}"
  else
    printf '%s' "${text:0:max}"
  fi
}

truncate_left() {
  local text="${1:-}"
  local max="${2:-0}"

  if (( ${#text} <= max )); then
    printf '%s' "$text"
  elif (( max > 3 )); then
    printf '...%s' "${text: -$((max - 3))}"
  else
    printf '%s' "${text: -max}"
  fi
}

format_day() {
  local ts="${1:-0}"

  if date -r "$ts" '+%b %d' >/dev/null 2>&1; then
    date -r "$ts" '+%b %d'
  else
    date -d "@$ts" '+%b %d'
  fi
}

format_age() {
  local ts="${1:-0}"
  local age

  if [[ -z "$ts" || "$ts" == "0" ]]; then
    printf -- '-'
    return
  fi

  age=$(( now_ts - ts ))

  if (( age < 0 )); then
    age=0
  fi

  if (( age < 60 )); then
    printf '%ss' "$age"
  elif (( age < 3600 )); then
    printf '%sm' "$(( age / 60 ))"
  elif (( age < 86400 )); then
    printf '%sh' "$(( age / 3600 ))"
  elif (( age < 604800 )); then
    printf '%sd' "$(( age / 86400 ))"
  else
    format_day "$ts"
  fi
}

# ANSI-aware truncate and pad to exact visible width.
# Preserves ANSI escape sequences, pads with spaces, appends reset.
ansi_truncpad() {
  local text="$1"
  local width="$2"
  local visible=0 i=0 len=${#text} result="" ch seq c

  while (( i < len && visible < width )); do
    ch="${text:i:1}"
    if [[ "$ch" == $'\033' ]]; then
      # Consume ANSI escape sequence: ESC [ ... (terminal letter)
      seq="$ch"
      i=$(( i + 1 ))
      if (( i < len )) && [[ "${text:i:1}" == "[" ]]; then
        seq+="${text:i:1}"
        i=$(( i + 1 ))
        while (( i < len )); do
          c="${text:i:1}"
          seq+="$c"
          i=$(( i + 1 ))
          [[ "$c" =~ [A-Za-z] ]] && break
        done
      fi
      result+="$seq"
    else
      result+="$ch"
      visible=$(( visible + 1 ))
      i=$(( i + 1 ))
    fi
  done

  # Pad with spaces to exact width
  while (( visible < width )); do
    result+=" "
    visible=$(( visible + 1 ))
  done

  result+=$'\033[0m'
  printf '%s' "$result"
}

# Render a composite preview of all panes in a window, matching native tmux choose-tree style.
# Usage: render_composite_preview "$target" [cols] [rows]
render_composite_preview() {
  local target="$1"
  local cols="${2:-${FZF_PREVIEW_COLUMNS:-80}}"
  local rows="${3:-${FZF_PREVIEW_LINES:-24}}"

  # Get window dimensions
  local win_dims
  win_dims="$(tmux display-message -p -t "$target" '#{window_width} #{window_height}' 2>/dev/null || true)"
  if [[ -z "$win_dims" ]]; then
    printf '%b%s%b\n' "$color_dim" "(window not found)" "$color_reset"
    return
  fi
  local win_w win_h
  read -r win_w win_h <<< "$win_dims"

  # Get pane geometry
  local -a p_ids p_lefts p_tops p_widths p_heights p_actives p_cmds
  local pane_count=0
  while IFS='|' read -r pid pleft ptop pwidth pheight pactive pcmd; do
    [[ -z "$pid" ]] && continue
    p_ids[pane_count]="$pid"
    p_lefts[pane_count]="$pleft"
    p_tops[pane_count]="$ptop"
    p_widths[pane_count]="$pwidth"
    p_heights[pane_count]="$pheight"
    p_actives[pane_count]="$pactive"
    p_cmds[pane_count]="$pcmd"
    pane_count=$(( pane_count + 1 ))
  done < <(tmux list-panes -t "$target" -F '#{pane_id}|#{pane_left}|#{pane_top}|#{pane_width}|#{pane_height}|#{pane_active}|#{pane_current_command}' 2>/dev/null)

  if (( pane_count == 0 )); then
    printf '%b%s%b\n' "$color_dim" "(no panes)" "$color_reset"
    return
  fi

  # Single pane fast path: no compositing, just capture
  if (( pane_count == 1 )); then
    tmux capture-pane -p -e -t "${p_ids[0]}" 2>/dev/null | tail -n "$rows"
    return
  fi

  # Fall back to plain capture if preview is too small
  if (( cols < 10 || rows < 5 )); then
    tmux capture-pane -p -e -t "${p_ids[0]}" 2>/dev/null | tail -n "$rows"
    return
  fi

  # Inner dimensions (inside outer border frame)
  local inner_w=$(( cols - 2 ))
  local inner_h=$(( rows - 2 ))

  # Scale pane positions to inner space
  local -a s_lefts s_tops s_widths s_heights
  local i s_right s_bot
  for (( i = 0; i < pane_count; i++ )); do
    s_lefts[i]=$(( p_lefts[i] * inner_w / win_w ))
    s_tops[i]=$(( p_tops[i] * inner_h / win_h ))
    s_right=$(( (p_lefts[i] + p_widths[i]) * inner_w / win_w ))
    s_bot=$(( (p_tops[i] + p_heights[i]) * inner_h / win_h ))
    s_widths[i]=$(( s_right - s_lefts[i] ))
    s_heights[i]=$(( s_bot - s_tops[i] ))
    (( s_widths[i] < 1 )) && s_widths[i]=1
    (( s_heights[i] < 1 )) && s_heights[i]=1
  done

  # Detect vertical border x-positions (where adjacent panes meet horizontally)
  local -A v_borders
  local j
  for (( i = 0; i < pane_count; i++ )); do
    local right_edge=$(( s_lefts[i] + s_widths[i] ))
    for (( j = 0; j < pane_count; j++ )); do
      (( i == j )) && continue
      # If another pane starts right after this one ends, there's a vertical border
      if (( s_lefts[j] == right_edge || s_lefts[j] == right_edge + 1 )); then
        v_borders[$right_edge]=1
      fi
    done
  done

  # Detect horizontal border y-positions (where adjacent panes meet vertically)
  local -A h_borders
  for (( i = 0; i < pane_count; i++ )); do
    local bot_edge=$(( s_tops[i] + s_heights[i] ))
    for (( j = 0; j < pane_count; j++ )); do
      (( i == j )) && continue
      if (( s_tops[j] == bot_edge || s_tops[j] == bot_edge + 1 )); then
        h_borders[$bot_edge]=1
      fi
    done
  done

  # Adjust pane positions to account for injected borders.
  # Each vertical border at position x shifts all panes to the right of x by 1.
  # Each horizontal border at position y shifts all panes below y by 1.
  local -a sorted_vb sorted_hb
  sorted_vb=($(printf '%s\n' "${!v_borders[@]}" | sort -n))
  sorted_hb=($(printf '%s\n' "${!h_borders[@]}" | sort -n))

  local num_vb=${#sorted_vb[@]}
  local num_hb=${#sorted_hb[@]}

  # Recalculate inner dimensions accounting for border lines
  local content_w=$(( inner_w - num_vb ))
  local content_h=$(( inner_h - num_hb ))

  if (( content_w < 2 || content_h < 2 )); then
    # Not enough room for borders + content, fall back
    tmux capture-pane -p -e -t "${p_ids[0]}" 2>/dev/null | tail -n "$rows"
    return
  fi

  # Rescale panes into content space (excluding border positions)
  for (( i = 0; i < pane_count; i++ )); do
    s_lefts[i]=$(( p_lefts[i] * content_w / win_w ))
    s_tops[i]=$(( p_tops[i] * content_h / win_h ))
    s_right=$(( (p_lefts[i] + p_widths[i]) * content_w / win_w ))
    s_bot=$(( (p_tops[i] + p_heights[i]) * content_h / win_h ))
    s_widths[i]=$(( s_right - s_lefts[i] ))
    s_heights[i]=$(( s_bot - s_tops[i] ))
    (( s_widths[i] < 1 )) && s_widths[i]=1
    (( s_heights[i] < 1 )) && s_heights[i]=1
  done

  # Re-detect borders in content coordinate space
  v_borders=()
  h_borders=()
  for (( i = 0; i < pane_count; i++ )); do
    local right_edge=$(( s_lefts[i] + s_widths[i] ))
    for (( j = 0; j < pane_count; j++ )); do
      (( i == j )) && continue
      if (( s_lefts[j] >= right_edge && s_lefts[j] <= right_edge + 1 )); then
        v_borders[$right_edge]=1
      fi
    done
    local bot_edge=$(( s_tops[i] + s_heights[i] ))
    for (( j = 0; j < pane_count; j++ )); do
      (( i == j )) && continue
      if (( s_tops[j] >= bot_edge && s_tops[j] <= bot_edge + 1 )); then
        h_borders[$bot_edge]=1
      fi
    done
  done

  sorted_vb=($(printf '%s\n' "${!v_borders[@]}" 2>/dev/null | sort -n))
  sorted_hb=($(printf '%s\n' "${!h_borders[@]}" 2>/dev/null | sort -n))

  # Capture all pane content into arrays
  # pane_lines_N_M holds line M of pane N
  local -A pane_lines
  local -a pane_line_counts
  for (( i = 0; i < pane_count; i++ )); do
    local capture_text
    capture_text="$(tmux capture-pane -p -e -t "${p_ids[i]}" 2>/dev/null || true)"
    local lnum=0
    if [[ -n "$capture_text" ]]; then
      while IFS= read -r line; do
        pane_lines["${i}_${lnum}"]="$line"
        lnum=$(( lnum + 1 ))
      done <<< "$capture_text"
    fi
    pane_line_counts[i]=$lnum
  done

  # Helper: map content y-coordinate to actual output y (inserting h-border rows)
  # and content x-coordinate to actual output x (inserting v-border cols)
  # We'll render in "output space" which includes border rows/cols.

  # Total output height = content_h + num_hb + 2 (outer borders)
  # Total output width  = content_w + num_vb + 2 (outer borders)

  # Build lookup: for output row, is it a h-border? and what content row does it map to?
  # Output row 0 = top border
  # Then content rows interleaved with h-border rows
  # Last row = bottom border

  local -a out_row_type  # "border" or "content"
  local -a out_row_cy    # content y for content rows
  local total_out_h=$(( content_h + num_hb + 2 ))
  local oi=0 cy=0 hi=0

  out_row_type[0]="top"
  oi=$(( oi + 1 ))

  while (( cy < content_h )); do
    # Check if there's a horizontal border at content y = cy
    if (( hi < num_hb && sorted_hb[hi] == cy )); then
      out_row_type[oi]="hborder"
      out_row_cy[oi]=$cy
      oi=$(( oi + 1 ))
      hi=$(( hi + 1 ))
    fi
    out_row_type[oi]="content"
    out_row_cy[oi]=$cy
    oi=$(( oi + 1 ))
    cy=$(( cy + 1 ))
  done
  # Any remaining h-borders at the end
  while (( hi < num_hb )); do
    out_row_type[oi]="hborder"
    out_row_cy[oi]=${sorted_hb[hi]}
    oi=$(( oi + 1 ))
    hi=$(( hi + 1 ))
  done

  out_row_type[oi]="bottom"
  oi=$(( oi + 1 ))

  # Build v-border set for quick lookup on content x
  local -A vb_set
  for (( i = 0; i < num_vb; i++ )); do
    vb_set[${sorted_vb[i]}]=1
  done

  # Render each output row
  local row_idx line_out
  for (( row_idx = 0; row_idx < oi; row_idx++ )); do
    local rtype="${out_row_type[row_idx]}"

    case "$rtype" in
      top)
        # ┌─────┬─────┐
        line_out="┌"
        local cx=0 vi=0
        while (( cx < content_w )); do
          if (( vi < num_vb && sorted_vb[vi] == cx )); then
            line_out+="┬"
            vi=$(( vi + 1 ))
          else
            line_out+="─"
            cx=$(( cx + 1 ))
          fi
        done
        line_out+="┐"
        printf '%s\n' "$line_out"
        ;;

      bottom)
        # └─────┴─────┘
        line_out="└"
        local cx=0 vi=0
        while (( cx < content_w )); do
          if (( vi < num_vb && sorted_vb[vi] == cx )); then
            line_out+="┴"
            vi=$(( vi + 1 ))
          else
            line_out+="─"
            cx=$(( cx + 1 ))
          fi
        done
        line_out+="┘"
        printf '%s\n' "$line_out"
        ;;

      hborder)
        # ├─────┼─────┤
        local border_y="${out_row_cy[row_idx]}"
        line_out="├"
        local cx=0 vi=0
        while (( cx < content_w )); do
          if (( vi < num_vb && sorted_vb[vi] == cx )); then
            # Determine connector: check if v-border exists above and below
            local has_above=0 has_below=0
            # v-border above: is there a pane boundary at this x in the row above?
            # v-border below: same for row below?
            # For simplicity, check if any pane has its right edge at cx
            # in the band above and below this h-border
            for (( k = 0; k < pane_count; k++ )); do
              local p_right=$(( s_lefts[k] + s_widths[k] ))
              if (( p_right == cx )); then
                if (( s_tops[k] < border_y )); then
                  has_above=1
                fi
                if (( s_tops[k] + s_heights[k] > border_y )); then
                  has_below=1
                fi
                if (( s_tops[k] >= border_y )); then
                  has_below=1
                fi
              fi
            done
            if (( has_above && has_below )); then
              line_out+="┼"
            elif (( has_above )); then
              line_out+="┴"
            elif (( has_below )); then
              line_out+="┬"
            else
              line_out+="┼"  # default to cross
            fi
            vi=$(( vi + 1 ))
          else
            line_out+="─"
            cx=$(( cx + 1 ))
          fi
        done
        line_out+="┤"
        printf '%s\n' "$line_out"
        ;;

      content)
        local cy="${out_row_cy[row_idx]}"
        line_out="│"

        # Find all panes active at this content y, sorted by s_left
        local -a active_panes=()
        for (( k = 0; k < pane_count; k++ )); do
          if (( cy >= s_tops[k] && cy < s_tops[k] + s_heights[k] )); then
            active_panes+=("$k")
          fi
        done

        # Sort by s_left (insertion sort — pane count is tiny)
        local n=${#active_panes[@]}
        for (( a = 1; a < n; a++ )); do
          local tmp=${active_panes[a]}
          local b=$a
          while (( b > 0 && s_lefts[active_panes[b-1]] > s_lefts[tmp] )); do
            active_panes[b]=${active_panes[b-1]}
            (( b-- ))
          done
          active_panes[b]=$tmp
        done

        local first=1
        local total_content_used=0
        for (( a = 0; a < n; a++ )); do
          local pi=${active_panes[a]}

          if (( first )); then
            first=0
          else
            line_out+="│"
          fi

          # Map content row to source line
          local pane_row=$(( cy - s_tops[pi] ))
          local src_row=$(( pane_row * p_heights[pi] / s_heights[pi] ))
          local src_line="${pane_lines["${pi}_${src_row}"]:-}"

          # Truncate/pad to scaled width
          local pw=${s_widths[pi]}
          line_out+="$(ansi_truncpad "$src_line" "$pw")"
          total_content_used=$(( total_content_used + pw ))
        done

        # Pad any remaining space (shouldn't happen if scaling is correct, but safety)
        local expected_w=$(( content_w + num_vb ))
        local got_w=$(( total_content_used + (n > 0 ? n - 1 : 0) ))
        while (( got_w < content_w + num_vb )); do
          line_out+=" "
          got_w=$(( got_w + 1 ))
        done

        line_out+="│"
        printf '%s\n' "$line_out"
        ;;
    esac
  done
}

preview_rule() {
  local cols="${FZF_PREVIEW_COLUMNS:-72}"

  if (( cols < 40 )); then
    cols=40
  fi

  printf '%*s\n' "$cols" '' | tr ' ' '-'
}

preview_section() {
  printf '%b%s%b\n' "$color_soft" "$1" "$color_reset"
  preview_rule
}

preview_pair() {
  local key="${1:-}"
  local value="${2:-}"

  printf '%b%-10s%b %b%s%b\n' "$color_dim" "$key" "$color_reset" "$color_fg" "$value" "$color_reset"
}

render_window_line() {
  local marker="${1:- }"
  local marker_color="${2:-$color_fg}"
  local label="${3:-}"
  local pane_count="${4:-0}"
  local cmd="${5:-}"
  local path="${6:-}"
  local age="${7:--}"
  local label_color="${8:-$color_bright}"
  local cmd_cell path_cell label_cell

  # Command-type color (inline to avoid subshell)
  local cmd_ansi
  case "$cmd" in
    zsh|bash|sh|fish|dash)           cmd_ansi="$color_cmd_shell" ;;
    nvim|vim|vi|emacs|nano|code|hx|kakoune) cmd_ansi="$color_cmd_editor" ;;
    node|npm|pnpm|yarn|bun|python|python3|cargo|go|make|ruby|deno|java|tsc|claude) cmd_ansi="$color_cmd_devrun" ;;
    git|lazygit|tig|gh|gitui)        cmd_ansi="$color_cmd_git" ;;
    yazi|ranger|nnn|lf|mc|vifm)      cmd_ansi="$color_cmd_filemgr" ;;
    htop|btop|top|watch|ps|journalctl|dmesg|strace|ltrace) cmd_ansi="$color_cmd_system" ;;
    ssh|mosh|telnet)                  cmd_ansi="$color_cmd_remote" ;;
    *)                                cmd_ansi="$color_cmd_other" ;;
  esac

  printf -v label_cell '%-24s' "$(truncate_right "$label" 24)"
  printf -v cmd_cell '%-18s' "$(truncate_right "$cmd" 18)"
  printf -v path_cell '%-36s' "$(truncate_left "$(shorten_home "$path")" 36)"

  printf '%b%s%b  %b%s%b  %b%3sp%b  %b%s%b  %b%s%b  %b%4s%b\n' \
    "$marker_color" "$marker" "$color_reset" \
    "$label_color" "$label_cell" "$color_reset" \
    "$color_fg" "$pane_count" "$color_reset" \
    "$cmd_ansi" "$cmd_cell" "$color_reset" \
    "$color_dim" "$path_cell" "$color_reset" \
    "$color_muted" "$age" "$color_reset"
}

current_pane_path() {
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p "#{pane_current_path}" 2>/dev/null || pwd
  else
    pwd
  fi
}

current_session() {
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p "#S" 2>/dev/null || true
  fi
}

pause_for_input() {
  printf '\nPress Enter to continue '
  IFS= read -r _
}

# Read a line with ESC-to-cancel and Ctrl-C protection.
# Returns 0 on Enter (result in REPLY), 1 on ESC/Ctrl-C.
read_input() {
  local prompt="${1:-}"
  local result=""
  local char next_char
  local _cancelled=0

  trap '_cancelled=1' INT
  printf '%s' "$prompt"

  while [[ "$_cancelled" == "0" ]]; do
    IFS= read -rsn1 char || { _cancelled=1; break; }
    case "$char" in
      $'\033')
        # Check if standalone ESC or start of escape sequence (arrow keys etc)
        IFS= read -rsn1 -t 0.01 next_char || true
        if [[ -z "$next_char" ]]; then
          _cancelled=1
          break
        fi
        # Consume rest of escape sequence
        IFS= read -rsn1 -t 0.01 _ || true
        ;;
      '')
        # Enter
        break
        ;;
      $'\177'|$'\b')
        # Backspace
        if [[ -n "$result" ]]; then
          result="${result%?}"
          printf '\b \b'
        fi
        ;;
      *)
        result+="$char"
        printf '%s' "$char"
        ;;
    esac
  done

  trap - INT
  printf '\n'

  if [[ "$_cancelled" == "1" ]]; then
    return 1
  fi

  REPLY="$result"
  return 0
}

session_window_rows() {
  local session="${1:-}"

  if [[ -z "$session" ]]; then
    return
  fi

  tmux list-windows -t "$session" -F '#{window_activity}|#{window_id}|#{window_index}|#{window_name}|#{window_active}|#{window_panes}|#{pane_current_command}|#{pane_current_path}' 2>/dev/null \
    | while IFS='|' read -r activity window_id window_index window_name window_active pane_count pane_cmd pane_path; do
        printf '%s\t%s:%s\t%s\t%s\t%s\t%s\t%s\n' \
          "$window_id" \
          "$window_index" \
          "$window_name" \
          "$window_active" \
          "$pane_count" \
          "$pane_cmd" \
          "$pane_path" \
          "$activity"
      done
}

emit_session_tree() {
  local name="${1:-}"
  local path="${2:-}"
  local windows="${3:-0}"
  local attached="${4:-0}"
  local age="${5:--}"
  local window_rows="${6:-}"
  local marker name_cell path_cell meta_cell display
  local window_id window_label window_active pane_count pane_cmd pane_path window_activity
  local window_marker tree_char cmd_ansi
  local w_name_cell w_path_cell w_age_cell

  # Session marker
  if [[ "$attached" != "0" ]]; then
    marker='*'
  else
    marker=' '
  fi

  # Inline shorten_home
  local short_path="$path"
  [[ "$short_path" == "$HOME/"* ]] && short_path="~/${short_path#$HOME/}"
  [[ "$short_path" == "$HOME" ]] && short_path="~"

  printf -v name_cell '%-18s' "$(truncate_right "$name" 18)"
  printf -v path_cell '%-38s' "$(truncate_left "$short_path" 38)"
  printf -v meta_cell '[%sw  %s]' "$windows" "$age"

  # Session line: bold name, warm marker for attached
  display="${color_warm}${marker}${color_reset}  ${color_bold}${color_bright}${name_cell}${color_reset}  ${color_dim}${path_cell}${color_reset}  ${color_muted}${meta_cell}${color_reset}"
  printf '%s\t%s\t%s\t%s\n' "session" "$name" "$name" "$display"

  # Count total windows for tree drawing
  local total_windows=0
  while IFS=$'\t' read -r window_id _; do
    [[ -z "${window_id:-}" ]] && continue
    total_windows=$(( total_windows + 1 ))
  done <<< "$window_rows"

  # Emit window lines with tree characters
  local window_num=0
  while IFS=$'\t' read -r window_id window_label window_active pane_count pane_cmd pane_path window_activity; do
    [[ -z "${window_id:-}" ]] && continue
    window_num=$(( window_num + 1 ))

    # Tree character
    if (( window_num == total_windows )); then
      tree_char='└─'
    else
      tree_char='├─'
    fi

    # Active marker
    if [[ "$window_active" == "1" ]]; then
      window_marker='*'
    else
      window_marker=' '
    fi

    # Command color (inline to avoid subshell)
    case "$pane_cmd" in
      zsh|bash|sh|fish|dash)           cmd_ansi="$color_cmd_shell" ;;
      nvim|vim|vi|emacs|nano|code|hx|kakoune) cmd_ansi="$color_cmd_editor" ;;
      node|npm|pnpm|yarn|bun|python|python3|cargo|go|make|ruby|deno|java|tsc|claude) cmd_ansi="$color_cmd_devrun" ;;
      git|lazygit|tig|gh|gitui)        cmd_ansi="$color_cmd_git" ;;
      yazi|ranger|nnn|lf|mc|vifm)      cmd_ansi="$color_cmd_filemgr" ;;
      htop|btop|top|watch|ps|journalctl|dmesg|strace|ltrace) cmd_ansi="$color_cmd_system" ;;
      ssh|mosh|telnet)                  cmd_ansi="$color_cmd_remote" ;;
      *)                                cmd_ansi="$color_cmd_other" ;;
    esac

    # Inline shorten_home
    local w_short_path="$pane_path"
    [[ "$w_short_path" == "$HOME/"* ]] && w_short_path="~/${w_short_path#$HOME/}"
    [[ "$w_short_path" == "$HOME" ]] && w_short_path="~"

    printf -v w_name_cell '%-22s' "$(truncate_right "$window_label" 22)"
    printf -v w_path_cell '%-44s' "$(truncate_left "$w_short_path" 44)"
    printf -v w_age_cell '%4s' "$(format_age "$window_activity")"

    local window_display
    if [[ "$window_active" == "1" ]]; then
      window_display="${color_dim}  ${tree_char}${color_reset} ${color_warm}${window_marker}${color_reset} ${cmd_ansi}${w_name_cell}${color_reset}  ${color_dim}${w_path_cell}${color_reset}  ${color_muted}${w_age_cell}${color_reset}"
    else
      window_display="${color_dim}  ${tree_char}${color_reset}   ${cmd_ansi}${w_name_cell}${color_reset}  ${color_dim}${w_path_cell}${color_reset}  ${color_muted}${w_age_cell}${color_reset}"
    fi

    printf '%s\t%s\t%s\t%s\n' "window" "$name" "$window_id" "$window_display"
  done <<< "$window_rows"
}

list_sessions() {
  local sessions_raw windows_raw

  # Two tmux calls total, regardless of session count
  sessions_raw="$(tmux list-sessions -F \
    '#{session_activity}|#{session_name}|#{session_windows}|#{session_attached}|#{session_path}' \
    2>/dev/null | sort -t '|' -k1,1nr)"

  [[ -z "$sessions_raw" ]] && return

  windows_raw="$(tmux list-windows -a -F \
    '#{session_name}|#{window_activity}|#{window_id}|#{window_index}|#{window_name}|#{window_active}|#{window_panes}|#{pane_current_command}|#{pane_current_path}' \
    2>/dev/null)"

  local activity name windows attached path age
  while IFS='|' read -r activity name windows attached path; do
    [[ -z "$name" ]] && continue
    age="$(format_age "$activity")"

    # Extract this session's windows from bulk data
    local session_windows=""
    while IFS='|' read -r sname wactivity wid widx wname wactive wpanes wcmd wpath; do
      [[ "$sname" != "$name" ]] && continue
      session_windows+="${wid}"$'\t'"${widx}:${wname}"$'\t'"${wactive}"$'\t'"${wpanes}"$'\t'"${wcmd}"$'\t'"${wpath}"$'\t'"${wactivity}"$'\n'
    done <<< "$windows_raw"

    emit_session_tree "$name" "$path" "$windows" "$attached" "$age" "$session_windows"
  done <<< "$sessions_raw"
}

preview_line() {
  local line="${1:-}"

  if [[ -z "$line" ]]; then
    exit 0
  fi

  # Use parameter expansion instead of cut (avoids subshells)
  local item_type session target rest
  item_type="${line%%$'\t'*}"
  rest="${line#*$'\t'}"
  session="${rest%%$'\t'*}"
  rest="${rest#*$'\t'}"
  target="${rest%%$'\t'*}"

  preview_item "$item_type" "$session" "$target"
}

preview_session() {
  local session="${1:-}"

  if [[ -z "$session" ]]; then
    exit 0
  fi

  local metadata path windows attached activity
  metadata="$(tmux display-message -p -t "$session" '#{session_path}|#{session_windows}|#{session_attached}|#{session_activity}' 2>/dev/null || true)"
  if [[ -z "$metadata" ]]; then
    printf 'Session not found: %s\n' "$session"
    exit 0
  fi

  IFS='|' read -r path windows attached activity <<<"$metadata"

  # Composite preview of active window (native tmux style)
  local preview_rows=$(( ${FZF_PREVIEW_LINES:-24} - 12 ))
  (( preview_rows < 5 )) && preview_rows=5
  render_composite_preview "$session" "${FZF_PREVIEW_COLUMNS:-80}" "$preview_rows"

  # Session info
  printf '\n'
  preview_section "SESSION"
  preview_pair "name" "$session"
  preview_pair "path" "$(shorten_home "$path")"
  preview_pair "windows" "$windows"
  if [[ "$attached" != "0" ]]; then
    preview_pair "attached" "yes"
  fi
  preview_pair "activity" "$(format_age "$activity") ago"

  # Window list
  local window_rows
  window_rows="$(session_window_rows "$session")"

  if [[ -n "$window_rows" ]]; then
    printf '\n'
    preview_section "WINDOWS"
    local window_id window_label window_active pane_count pane_cmd pane_path window_activity
    while IFS=$'\t' read -r window_id window_label window_active pane_count pane_cmd pane_path window_activity; do
      [[ -z "${window_id:-}" ]] && continue
      if [[ "$window_active" == "1" ]]; then
        render_window_line "*" "$color_warm" "$window_label" "$pane_count" "$pane_cmd" "$pane_path" "$(format_age "$window_activity")" "$color_bright"
      else
        render_window_line " " "$color_dim" "$window_label" "$pane_count" "$pane_cmd" "$pane_path" "$(format_age "$window_activity")" "$color_fg"
      fi
    done <<< "$window_rows"
  fi
}

preview_window() {
  local session="${1:-}"
  local window_id="${2:-}"
  local metadata window_index window_name pane_count pane_cmd pane_path activity

  if [[ -z "$window_id" ]]; then
    exit 0
  fi

  metadata="$(tmux display-message -p -t "$window_id" '#{window_index}|#{window_name}|#{window_panes}|#{pane_current_command}|#{pane_current_path}|#{window_activity}' 2>/dev/null || true)"
  if [[ -z "$metadata" ]]; then
    printf 'Window not found: %s\n' "$window_id"
    exit 0
  fi

  IFS='|' read -r window_index window_name pane_count pane_cmd pane_path activity <<<"$metadata"

  # Composite preview (native tmux style — all panes in layout)
  local preview_rows=$(( ${FZF_PREVIEW_LINES:-24} - 8 ))
  (( preview_rows < 5 )) && preview_rows=5
  render_composite_preview "$window_id" "${FZF_PREVIEW_COLUMNS:-80}" "$preview_rows"

  # Compact metadata footer
  printf '\n'
  preview_section "INFO"
  preview_pair "session" "$session"
  preview_pair "window" "${window_index}:${window_name}"
  preview_pair "command" "$pane_cmd"
  preview_pair "path" "$(shorten_home "$pane_path")"
  preview_pair "panes" "$pane_count"
  preview_pair "activity" "$(format_age "$activity") ago"
}

preview_item() {
  local item_type="${1:-}"
  local session="${2:-}"
  local target="${3:-}"

  case "$item_type" in
    session)
      preview_session "$session"
      ;;
    window)
      preview_window "$session" "$target"
      ;;
  esac
}

prompt_new_session() {
  local dir default_name name

  dir="$(current_pane_path)"
  default_name="$(basename "$dir")"
  if [[ -z "$default_name" || "$default_name" == "/" || "$default_name" == "." ]]; then
    default_name="main"
  fi

  printf 'New session name [%s]: ' "$default_name"
  IFS= read -r name
  name="${name:-$default_name}"

  if [[ -z "$name" ]]; then
    return
  fi

  if tmux has-session -t "$name" 2>/dev/null; then
    printf 'Session already exists: %s\n' "$name"
    pause_for_input
    return
  fi

  tmux new-session -d -s "$name" -c "$dir"
}

prompt_rename_session() {
  local session="${1:-}"
  local new_name

  if [[ -z "$session" ]]; then
    return
  fi

  # Show context: active window capture
  local pane_id capture metadata path windows
  metadata="$(tmux display-message -p -t "$session" '#{session_path}|#{session_windows}' 2>/dev/null || true)"
  IFS='|' read -r path windows <<<"$metadata"
  pane_id="$(tmux display-message -p -t "$session" '#{pane_id}' 2>/dev/null || true)"
  if [[ -n "$pane_id" ]]; then
    capture="$(tmux capture-pane -p -e -t "$pane_id" -S - -E - 2>/dev/null | tail -n 15 || true)"
    if [[ -n "$capture" ]]; then
      printf '\n'
      preview_section "PEEK"
      printf '%s\n' "$capture"
    fi
  fi
  printf '\n'
  preview_section "SESSION"
  preview_pair "session" "$session"
  preview_pair "path" "$(shorten_home "$path")"
  preview_pair "windows" "$windows"
  printf '\n'
  printf '%b%s%b\n' "$color_dim" "────────────────────────────────" "$color_reset"
  if ! read_input "$(printf 'Rename %b%s%b to: ' "$color_bright" "$session" "$color_reset")"; then
    return
  fi
  new_name="$REPLY"

  if [[ -z "$new_name" || "$new_name" == "$session" ]]; then
    return
  fi

  if tmux has-session -t "$new_name" 2>/dev/null; then
    printf 'Session already exists: %s\n' "$new_name"
    pause_for_input
    return
  fi

  tmux rename-session -t "$session" "$new_name"
}

prompt_rename_window() {
  local window_id="${1:-}"
  local current_name new_name

  if [[ -z "$window_id" ]]; then
    return
  fi

  # Show context: terminal capture of the window being renamed
  local pane_id capture metadata pane_cmd pane_path
  metadata="$(tmux display-message -p -t "$window_id" '#W|#{pane_current_command}|#{pane_current_path}' 2>/dev/null || true)"
  IFS='|' read -r current_name pane_cmd pane_path <<<"$metadata"
  pane_id="$(tmux display-message -p -t "$window_id" '#{pane_id}' 2>/dev/null || true)"
  if [[ -n "$pane_id" ]]; then
    capture="$(tmux capture-pane -p -e -t "$pane_id" -S - -E - 2>/dev/null | tail -n 15 || true)"
    if [[ -n "$capture" ]]; then
      printf '\n'
      preview_section "PEEK"
      printf '%s\n' "$capture"
    fi
  fi
  printf '\n'
  preview_section "WINDOW"
  preview_pair "window" "${current_name:-window}"
  preview_pair "command" "$pane_cmd"
  preview_pair "path" "$(shorten_home "$pane_path")"
  printf '\n'
  printf '%b%s%b\n' "$color_dim" "────────────────────────────────" "$color_reset"
  if ! read_input "$(printf 'Rename %b%s%b to: ' "$color_bright" "${current_name:-window}" "$color_reset")"; then
    return
  fi
  new_name="$REPLY"

  if [[ -z "$new_name" || "$new_name" == "$current_name" ]]; then
    return
  fi

  tmux rename-window -t "$window_id" "$new_name"
}

prompt_kill_session() {
  local session="${1:-}"
  local current answer

  if [[ -z "$session" ]]; then
    return
  fi

  current="$(current_session)"
  if [[ -n "$current" && "$current" == "$session" ]]; then
    printf 'Refusing to kill current session: %s\n' "$session"
    pause_for_input
    return
  fi

  printf 'Kill %s? [y/N]: ' "$session"
  IFS= read -r answer
  case "$answer" in
    y|Y|yes|YES)
      tmux kill-session -t "$session"
      ;;
  esac
}

prompt_kill_window() {
  local window_id="${1:-}"
  local label answer

  if [[ -z "$window_id" ]]; then
    return
  fi

  label="$(tmux display-message -p -t "$window_id" '#S:#{window_index}:#{window_name}' 2>/dev/null || true)"
  printf 'Kill %s? [y/N]: ' "${label:-window}"
  IFS= read -r answer
  case "$answer" in
    y|Y|yes|YES)
      tmux kill-window -t "$window_id"
      ;;
  esac
}

switch_or_attach() {
  local session="${1:-}"

  if [[ -z "$session" ]]; then
    return
  fi

  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$session"
  else
    exec tmux attach-session -t "$session"
  fi
}

switch_to_window() {
  local window_id="${1:-}"
  local session_name

  if [[ -z "$window_id" ]]; then
    return
  fi

  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$window_id"
  else
    session_name="$(tmux display-message -p -t "$window_id" '#S' 2>/dev/null || true)"
    if [[ -z "$session_name" ]]; then
      return
    fi
    exec tmux attach-session -t "$session_name" \; select-window -t "$window_id"
  fi
}

run_session_picker() {
  local output key selected item_type session target
  local fzf_help
  local -a fzf_opts picker_opts

  if ! tmux list-sessions >/dev/null 2>&1; then
    printf 'No tmux sessions found\n'
    exit 1
  fi

  fzf_help="$(fzf --help 2>&1 || true)"

  fzf_opts=(
    --layout=reverse
    --border=rounded
    --padding=1
    --info=inline-right
    --cycle
    '--pointer=>'
    '--marker=*'
    "--color=fg:${fg_hex},bg:-1,fg+:${bright_hex},bg+:${row_hex},hl:${accent_hex},hl+:${warm_hex},info:${dim_hex},prompt:${accent_hex},pointer:${accent_hex},marker:${warm_hex},spinner:${accent_hex},header:${dim_hex},border:${border_hex},label:${accent_hex},preview-border:${border_hex},preview-label:${accent_hex}"
  )

  [[ "$fzf_help" == *"--style"* ]] && fzf_opts+=(--style=full)
  [[ "$fzf_help" == *"--list-border"* ]] && fzf_opts+=(--list-border=rounded)
  [[ "$fzf_help" == *"--input-border"* ]] && fzf_opts+=(--input-border=line)
  [[ "$fzf_help" == *"--header-border"* ]] && fzf_opts+=(--header-border=line)
  [[ "$fzf_help" == *"--footer-border"* ]] && fzf_opts+=(--footer-border=line)
  [[ "$fzf_help" == *"--highlight-line"* ]] && fzf_opts+=(--highlight-line)

  picker_opts=(
    --prompt='> '
    --header='Sessions and windows. Type to filter.'
    --header-first
    --footer='enter open  ctrl-n new  ctrl-r rename  ctrl-x kill  ctrl-/ preview'
    --preview="$0 preview-item {1} {2} {3}"
    --preview-window='right:56%,wrap'
    --bind="start:reload-sync($0 list)+first"
    --bind='ctrl-/:toggle-preview'
    --expect=enter,ctrl-n,ctrl-r,ctrl-x
  )

  [[ "$fzf_help" == *"--ghost"* ]] && picker_opts+=(--ghost='type to filter sessions and windows')
  [[ "$fzf_help" == *"--input-label"* ]] && picker_opts+=(--input-label=' filter ')
  [[ "$fzf_help" == *"--list-label"* ]] && picker_opts+=(--list-label=' sessions + windows ')
  [[ "$fzf_help" == *"--header-label"* ]] && picker_opts+=(--header-label=' scope ')
  [[ "$fzf_help" == *"--footer-label"* ]] && picker_opts+=(--footer-label=' actions ')
  [[ "$fzf_help" == *"--preview-label"* ]] && picker_opts+=(--preview-label=' details ')

  while true; do
    output="$(
      printf '' | fzf \
        "${fzf_opts[@]}" \
        "${picker_opts[@]}" \
        --ansi \
        --delimiter=$'\t' \
        --with-nth=4 \
        --border-label=' session picker '
    )" || return 0

    key="$(printf '%s\n' "$output" | sed -n '1p')"
    selected="$(printf '%s\n' "$output" | sed -n '2p')"
    item_type="$(printf '%s\n' "$selected" | cut -f1)"
    session="$(printf '%s\n' "$selected" | cut -f2)"
    target="$(printf '%s\n' "$selected" | cut -f3)"

    case "$key" in
      enter)
        if [[ "$item_type" == "window" ]]; then
          switch_to_window "$target"
        else
          switch_or_attach "$session"
        fi
        return 0
        ;;
      ctrl-n)
        prompt_new_session
        ;;
      ctrl-r)
        if [[ "$item_type" == "window" ]]; then
          prompt_rename_window "$target"
        else
          prompt_rename_session "$session"
        fi
        ;;
      ctrl-x)
        if [[ "$item_type" == "window" ]]; then
          prompt_kill_window "$target"
        else
          prompt_kill_session "$session"
        fi
        ;;
    esac
  done
}

strip_ansi() {
  sed 's/\x1b\[[0-9;]*[A-Za-z]//g'
}

test_composite() {
  local cols="${1:-60}"
  local rows="${2:-20}"
  local test_session="_test_composite_$$"
  local pass=0 fail=0

  printf 'Testing composite renderer at %dx%d\n\n' "$cols" "$rows"

  # Create test session
  tmux new-session -d -s "$test_session" -x 160 -y 40 2>/dev/null
  sleep 0.3
  local base_window
  base_window="$(tmux list-windows -t "$test_session" -F '#{window_id}' | head -1)"

  run_test() {
    local name="$1" target="$2" expected_panes="$3"
    local output errors="" line_num=0 first_line="" last_line=""
    local width_ok=1 border_ok=1 content_found=0

    output="$(render_composite_preview "$target" "$cols" "$rows" 2>&1)"

    if [[ -z "$output" ]]; then
      if (( expected_panes <= 1 )); then
        printf '  %-20s PASS (empty single pane)\n' "$name:"
        pass=$(( pass + 1 ))
        return
      fi
      printf '  %-20s FAIL (no output)\n' "$name:"
      fail=$(( fail + 1 ))
      return
    fi

    while IFS= read -r line; do
      line_num=$(( line_num + 1 ))
      local visible
      visible="$(printf '%s' "$line" | strip_ansi)"
      local vlen=${#visible}

      # For multi-pane (has borders), check width
      if (( expected_panes > 1 )); then
        if (( vlen != cols )); then
          width_ok=0
          errors+="  line $line_num: visible width=$vlen (expected $cols)\n"
        fi

        if (( line_num == 1 )); then
          first_line="$visible"
          if [[ "${visible:0:3}" != "┌─" && "${visible:0:1}" != "┌" ]]; then
            border_ok=0
            errors+="  line 1: doesn't start with ┌\n"
          fi
        fi
      fi

      # Check for non-border content (ANSI resets from renderer count)
      local stripped="${visible//[─│┌┐└┘├┤┬┴┼ ]/}"
      if [[ -n "$stripped" ]]; then
        content_found=1
      fi
      # Also check for ANSI resets which our renderer always produces
      if [[ "$line" == *$'\033[0m'* ]]; then
        content_found=1
      fi
    done <<< "$output"

    if (( expected_panes > 1 )); then
      last_line="$(printf '%s' "$output" | tail -1 | strip_ansi)"
      if [[ "${last_line:0:1}" != "└" ]]; then
        border_ok=0
        errors+="  last line: doesn't start with └\n"
      fi
    fi

    # For single-pane, content check is trivially true (no borders to confuse)
    if (( expected_panes <= 1 )); then
      content_found=1
    fi

    if (( width_ok && border_ok && content_found )); then
      printf '  %-20s PASS (%d lines)\n' "$name:" "$line_num"
      pass=$(( pass + 1 ))
    else
      printf '  %-20s FAIL\n' "$name:"
      [[ -n "$errors" ]] && printf '%b' "$errors"
      fail=$(( fail + 1 ))
    fi
  }

  # Test 1: Single pane (fast path, no borders)
  run_test "1-pane" "$base_window" 1

  # Test 2: Two panes - vertical split (side by side)
  tmux new-window -t "$test_session"
  local win2
  win2="$(tmux list-windows -t "$test_session" -F '#{window_id}' | tail -1)"
  tmux split-window -h -t "$win2"
  sleep 0.1
  run_test "2-pane-vsplit" "$win2" 2

  # Test 3: Two panes - horizontal split (stacked)
  tmux new-window -t "$test_session"
  local win3
  win3="$(tmux list-windows -t "$test_session" -F '#{window_id}' | tail -1)"
  tmux split-window -v -t "$win3"
  sleep 0.1
  run_test "2-pane-hsplit" "$win3" 2

  # Test 4: Three panes - L-shape
  tmux new-window -t "$test_session"
  local win4
  win4="$(tmux list-windows -t "$test_session" -F '#{window_id}' | tail -1)"
  tmux split-window -h -t "$win4"
  tmux split-window -v -t "$win4"
  sleep 0.1
  run_test "3-pane-L" "$win4" 3

  # Test 5: Four panes - 2x2 grid
  tmux new-window -t "$test_session"
  local win5
  win5="$(tmux list-windows -t "$test_session" -F '#{window_id}' | tail -1)"
  tmux split-window -h -t "$win5"
  tmux select-pane -t "$win5.1"
  tmux split-window -v -t "$win5"
  tmux select-pane -t "$win5.3"
  tmux split-window -v -t "$win5"
  sleep 0.1
  run_test "4-pane-grid" "$win5" 4

  # Cleanup
  tmux kill-session -t "$test_session" 2>/dev/null

  printf '\n%d passed, %d failed\n' "$pass" "$fail"
  (( fail > 0 )) && return 1
  return 0
}

main() {
  require_cmd tmux
  require_cmd fzf

  case "${1:-run}" in
    list)
      list_sessions
      ;;
    query-list)
      # Backward compat: fzf handles filtering now, just list all
      list_sessions
      ;;
    preview|preview-session)
      preview_session "${2:-}"
      ;;
    preview-line)
      preview_line "${2:-}"
      ;;
    preview-item)
      preview_item "${2:-}" "${3:-}" "${4:-}"
      ;;
    run|sessions)
      run_session_picker
      ;;
    test-composite)
      test_composite "${2:-60}" "${3:-20}"
      ;;
    render-preview)
      render_composite_preview "${2:-}" "${3:-80}" "${4:-20}"
      ;;
    *)
      printf 'Usage: %s [sessions|list|preview-item <type> <session> <target>|test-composite [cols] [rows]]\n' "$0" >&2
      exit 1
      ;;
  esac
}

main "$@"
