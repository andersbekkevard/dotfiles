# Ghostty configuration managed by dotfiles.

# font-family = "MesloLGSDZ Nerd Font Mono"
# font-family = Monaco
# font-family = "JetBrains Mono Medium"
# font-family = monospace
font-size = 16

# theme = Brogrammer
# theme = Dracula+
# theme = Gruvbox Dark Hard
# theme = iTerm2 Default
# theme = Seti
# theme = Cursor Dark
theme = Apple System Colors
# theme = Afterglow

title =
window-title-font-family = "MonoLisa Variable"
window-save-state = always

# Let both Option keys behave as Alt/Meta so tmux M- bindings work.
macos-option-as-alt = true

# Restore Norwegian Option+7/8/9 symbols while keeping Option as Alt.
keybind = alt+7=text:|
keybind = alt+8=text:[
keybind = alt+9=text:]
keybind = alt+shift+8=text:{
keybind = alt+shift+9=text:}

# Shift+Enter sends newline sequence for Claude Code.
keybind = shift+enter=text:\x1b\r

# Make Cmd+Z send Alt+Z (undo in zsh).
keybind = super+z=esc:z

# Make Cmd+Shift+Z send Alt+Y (redo in zsh).
keybind = super+shift+z=esc:y

# Extend selection to the beginning or end of the line.
keybind = super+shift+left=adjust_selection:beginning_of_line
keybind = super+shift+right=adjust_selection:end_of_line

# Extend selection character-wise with Option+Shift+Arrow.
keybind = alt+shift+left=adjust_selection:left
keybind = alt+shift+right=adjust_selection:right

# Norwegian-specific home row split navigation.
keybind = super+ø=goto_split:previous
keybind = super+æ=goto_split:next

# Allow OSC 52 clipboard reads for clipboard over SSH/tmux.
clipboard-read = allow

